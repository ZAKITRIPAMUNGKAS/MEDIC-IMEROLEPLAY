    <script>
        // Trigger animations on slide
        function playSlideAnimations(slide) {
            const animatedElements = slide.querySelectorAll('.animate-in');
            animatedElements.forEach((el, index) => {
                // Remove show class first to reset
                el.classList.remove('show');
                // Add show class with slight delay to trigger animation
                setTimeout(() => {
                    el.classList.add('show');
                }, 50 + (index * 20)); // Slight stagger even within same delay class
            });
        }

        // Number Count Up
        function animateValue(obj, start, end, duration) {
            if (!obj) return; // Safety check
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                obj.innerHTML = Math.floor(progress * (end - start) + start).toLocaleString('id-ID');
                if (progress < 1) {
                    window.requestAnimationFrame(step);
                }
            };
            window.requestAnimationFrame(step);
        }

        // Story Progress Bars
        const totalSlides = document.querySelectorAll('.swiper-slide').length;
        const navContainer = document.getElementById('storyNav');
        
        for(let i=0; i<totalSlides; i++) {
            const bar = document.createElement('div');
            bar.className = 'story-bar';
            bar.innerHTML = `<div class="story-progress" id="progress-${i}"></div>`;
            navContainer.appendChild(bar);
        }

        function updateProgress(activeIndex) {
            for(let i=0; i<totalSlides; i++) {
                const el = document.getElementById(`progress-${i}`);
                if (i < activeIndex) el.style.width = '100%';
                else if (i === activeIndex) {
                    el.style.width = '0%';
                    setTimeout(() => el.style.width = '100%', 50);
                } else el.style.width = '0%';
            }
        }

        // Swiper Init
        const swiper = new Swiper('.mySwiper', {
            effect: 'creative',
            creativeEffect: {
                prev: {
                    shadow: true,
                    translate: [0, 0, -400],
                    opacity: 0,
                },
                next: {
                    translate: [0, '100%', 0],
                },
            },
            direction: 'vertical',
            speed: 700,
            on: {
                init: function() {
                    updateProgress(0);
                    // Trigger animations on first slide
                    playSlideAnimations(this.slides[0]);
                },
                slideChange: function() {
                    updateProgress(this.activeIndex);
                    const currentSlide = this.slides[this.activeIndex];
                    
                    // Trigger animations for current slide
                    playSlideAnimations(currentSlide);
                    const slideType = currentSlide.getAttribute('data-slide');
                    
                    if(slideType === 'patients') {
                        const el = document.getElementById('totalPatients');
                        el.innerText = '0';
                        setTimeout(() => animateValue(el, 0, {{ $stats['total_patients'] }}, 1500), 500);
                    }

                    if(slideType === 'badge') {
                        setTimeout(() => {
                            confetti({
                                particleCount: 100,
                                spread: 70,
                                origin: { y: 0.6 },
                                colors: ['#fbbf24', '#f59e0b', '#ffffff']
                            });
                        }, 600);
                    }

                    if(slideType === 'outro') {
                        var duration = 3 * 1000;
                        var animationEnd = Date.now() + duration;
                        var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };
                        var randomInRange = (min, max) => Math.random() * (max - min) + min;

                        var interval = setInterval(function () {
                            var timeLeft = animationEnd - Date.now();
                            if (timeLeft <= 0) return clearInterval(interval);
                            var particleCount = 50 * (timeLeft / duration);
                            confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                            confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
                        }, 250);
                    }

                    if (navigator.vibrate) navigator.vibrate(15);
                }
            }
        });

        // Money Rain Effect
        function triggerMoneyRain() {
            const container = document.getElementById('moneyContainer');
            const emojis = ['💸', '💵', '💎', '🏥'];
            
            container.innerHTML = '';

            for (let i = 0; i < 30; i++) {
                const el = document.createElement('div');
                el.innerText = emojis[Math.floor(Math.random() * emojis.length)];
                el.style.position = 'absolute';
                el.style.left = Math.random() * 100 + '%';
                el.style.top = '-50px';
                el.style.fontSize = (Math.random() * 20 + 20) + 'px';
                
                el.animate([
                    { transform: `translateY(0) rotate(0deg)` },
                    { transform: `translateY(110vh) rotate(${Math.random() * 360}deg)` }
                ], {
                    duration: Math.random() * 2000 + 2000,
                    easing: 'linear',
                    fill: 'forwards'
                });

                container.appendChild(el);
            }
        }

        // Close Logic
        function closeWrapped() {
            const wrapper = document.querySelector('.swiper');
            wrapper.style.transition = 'all 0.5s ease';
            wrapper.style.opacity = '0';
            wrapper.style.transform = 'scale(0.9)';

            document.getElementById('storyNav').style.opacity = '0';
            
            setTimeout(() => {
                fetch('{{ route("wrapped.dismiss") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': '{{ csrf_token() }}' },
                    body: JSON.stringify({ year: {{ $year }} })
                }).finally(() => {
                    sessionStorage.setItem('wrapped_{{ $year }}_seen', 'true');
                    window.location.href = '{{ route("staff.dashboard") }}';
                });
            }, 500);
        }

        // 3D Tilt Effect
        document.addEventListener('mousemove', (e) => {
            const cards = document.querySelectorAll('.tilt-card');
            const x = (window.innerWidth / 2 - e.pageX) / 25;
            const y = (window.innerHeight / 2 - e.pageY) / 25;

            cards.forEach(card => {
                card.style.transform = `rotateY(${x}deg) rotateX(${y}deg)`;
            });
        });
        
    </script>
</body>
</html>